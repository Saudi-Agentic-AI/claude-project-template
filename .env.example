# .env.example — authoritative inventory of every env var this project reads.
#
# Copy this to .env locally:    cp .env.example .env
# Then fill in the values for the services your project actually uses.
# Delete sections for services you don't use.
#
# Rules:
#   - .env is gitignored. Never commit it.
#   - When you add a new env var reference in code, add a placeholder here
#     in the same change. The sync-env-example.sh hook enforces this.
#   - See .claude/rules/secrets-and-env.md for the full pattern.
#
# Per-environment isolation:
#   - SECRET_KEY: MUST differ per environment
#   - TELEGRAM_ADMIN_CHAT_ID: MUST differ per environment (dev noise out of prod alerts)
#   - DATABASE_URL / REDIS_URL: MUST differ per environment (hard rule)
#   - Vendor API keys (Anthropic, Postmark, etc.): may be shared with caution


# === Runtime ===
# ENVIRONMENT — one of: development, staging, production
ENVIRONMENT=development

# LOG_LEVEL — one of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


# === Database (Postgres via Railway plugin) ===
# DATABASE_URL — Postgres connection string.
# Railway injects this automatically when you attach the Postgres plugin.
# Local format: postgresql+asyncpg://user:pass@localhost:5432/dbname
DATABASE_URL=


# === Cache / counters (Redis via Railway plugin) ===
# REDIS_URL — Redis connection string.
# Railway injects this automatically when you attach the Redis plugin.
# Empty → app fails open (counters / rate limits become no-ops).
REDIS_URL=


# === App secrets ===
# SECRET_KEY — app-internal signing key (JWT, CSRF, cookie sessions).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be unique per environment.
SECRET_KEY=


# === AI: Anthropic (primary) ===
# ANTHROPIC_API_KEY — from console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL — default model for non-reasoning calls
ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_MAX_OUTPUT_TOKENS — guardrail on response size
ANTHROPIC_MAX_OUTPUT_TOKENS=4096


# === AI: OpenRouter (fallback / cost-sensitive) ===
# OPENROUTER_API_KEY — from openrouter.ai → Keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL — default model (use :nitro suffix for faster routing)
OPENROUTER_MODEL=deepseek/deepseek-chat:nitro
# AI_PROVIDER — switch dispatch: "anthropic" or "openrouter"
AI_PROVIDER=anthropic


# === Email (Postmark) ===
# POSTMARK_API_TOKEN — from postmarkapp.com → Servers → API Tokens
# Empty → log-only mode (useful in dev / CI / before vendor signup)
POSTMARK_API_TOKEN=
# POSTMARK_FROM_ADDRESS — verified sender address
POSTMARK_FROM_ADDRESS=
# POSTMARK_WEBHOOK_USER / _PASSWORD — Basic auth for bounce/complaint webhook
POSTMARK_WEBHOOK_USER=
POSTMARK_WEBHOOK_PASSWORD=


# === Notifications: Telegram ===
# TELEGRAM_BOT_TOKEN — create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME — bot's @username (without the @)
TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET — random string, sent in X-Telegram-Bot-Api-Secret-Token
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=
# TELEGRAM_ADMIN_CHAT_ID — your personal chat_id (DM @userinfobot to find)
# MUST be different per environment.
TELEGRAM_ADMIN_CHAT_ID=


# === Notifications: WhatsApp (Kapso.ai or similar wrapper) ===
# KAPSO_API_KEY — from kapso.ai dashboard
# Skip if WhatsApp not in scope.
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=


# === Observability: Sentry ===
# SENTRY_DSN — from sentry.io → Settings → Projects → <name> → Client Keys
# Empty → no-op (dev / CI / preview deploys)
SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE — fraction of requests to trace (0.0–1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT — usually mirrors ENVIRONMENT above
SENTRY_ENVIRONMENT=development


# === Market data / domain-specific vendors ===
# Add your project's domain-specific API keys here. Examples:
# SAHMK_API_KEY=
# YFINANCE_CACHE_TTL=300


# === Payment processor (only if monetizing) ===
# MOYASAR_API_KEY — from dashboard.moyasar.com (SAR / GCC)
# STRIPE_API_KEY — from dashboard.stripe.com (global)
# Skip the section that doesn't apply.
MOYASAR_API_KEY=
MOYASAR_WEBHOOK_SECRET=
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=


# === Auth (planned: in-house JWT) ===
# JWT_ACCESS_TTL_MINUTES — short-lived access token lifetime
JWT_ACCESS_TTL_MINUTES=30
# JWT_REFRESH_TTL_DAYS — refresh token lifetime
JWT_REFRESH_TTL_DAYS=30


# === Deploy-target injected (DO NOT set manually; provided by host) ===
# RAILWAY_GIT_COMMIT_SHA — Railway injects per deploy; used for Sentry release tagging
# RAILWAY_ENVIRONMENT — "production" / "development"
# These are listed for reference only — do not put values here.
